{
  "name": "skill-doc-generator",
  "version": "0.1.1",
  "description": "MCP server that generates Claude Code skill files from documentation URLs",
  "license": "MIT",
  "author": "Edgar Milá",
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "skill",
    "documentation"
  ],
  "type": "module",
  "bin": {
    "skill-doc-generator": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
